<% layout("/layouts/boilerplate") %>

<section id="listingsPage">
  <div class="container">

    <%
      const hasFilters = (typeof search !== 'undefined' && search) ||
                         (typeof category !== 'undefined' && category) ||
                         (typeof maxPrice !== 'undefined' && maxPrice) ||
                         (typeof sort !== 'undefined' && sort);
    %>

    <!-- Filter Feedback Bar -->
    <% if (hasFilters) { %>
      <div class="filter-feedback-bar">
        <span class="filter-feedback-text">
          <i class="fa-solid fa-filter me-1"></i>
          Showing <strong><%= allListings.length %></strong> result<%= allListings.length !== 1 ? 's' : '' %>
          <% if (typeof search !== 'undefined' && search) { %>
            for <em>"<%= search %>"</em>
          <% } %>
          <% if (typeof category !== 'undefined' && category) { %>
            in <strong class="filter-category-badge"><%= category %></strong>
          <% } %>
          <% if (typeof maxPrice !== 'undefined' && maxPrice) { %>
            · under <strong>₹<%= parseInt(maxPrice).toLocaleString('en-IN') %></strong>
          <% } %>
        </span>
        <a href="/listings" class="filter-clear-link">
          <i class="fa-solid fa-xmark me-1"></i>Clear filters
        </a>
      </div>
    <% } %>

    <!-- Page Header -->
    <div class="listings-header">
      <div>
        <h1 class="listings-title">
          <% if (typeof category !== 'undefined' && category) { %>
            <%= category.charAt(0).toUpperCase() + category.slice(1) %> Stays
          <% } else if (typeof search !== 'undefined' && search) { %>
            Results for "<%= search %>"
          <% } else { %>
            Explore Places to Stay
          <% } %>
        </h1>
        <p class="listings-subtitle">
          <%= allListings.length %> propert<%= allListings.length !== 1 ? 'ies' : 'y' %> available
        </p>
      </div>

      <!-- Add Listing only shows to logged-in users in the page header -->
      <% if (currUser) { %>
        <a href="/listings/new" class="btn btn-add-listing">
          <i class="fa-solid fa-plus me-2"></i>Add Listing
        </a>
      <% } else { %>
        <a href="/login" class="btn btn-add-listing">
          <i class="fa-solid fa-plus me-2"></i>Add Listing
        </a>
      <% } %>
    </div>

    <!-- ── Listings Grid ── -->
    <% if (allListings.length > 0) { %>

      <div class="listings-grid">
        <% for (let listing of allListings) { %>

          <%
            // Compute real average rating from reviews array
            // Each review must have a .rating field (number 1-5)
            let avgRating = null;
            if (listing.reviews && listing.reviews.length > 0) {
              const sum = listing.reviews.reduce((acc, r) => acc + (r.rating || 0), 0);
              avgRating = (sum / listing.reviews.length).toFixed(1);
            }

            // Cloudinary image optimization:
            // Serves a cropped, WebP-converted, quality-auto version at card size
            // Falls back to original URL if not a Cloudinary URL
            let cardImageUrl = listing.image && listing.image.url ? listing.image.url : '';
            if (cardImageUrl.includes('res.cloudinary.com')) {
              cardImageUrl = cardImageUrl.replace('/upload/', '/upload/w_600,h_450,c_fill,f_auto,q_auto/');
            }
          %>

          <div class="listing-card-wrapper">

            <!--
              HEART / WISHLIST BUTTON
              FIX: auth state is passed from EJS so guests are redirected to login.
              For logged-in users, the state is seeded from their actual wishlist array.
            -->
            <%
              const isLoggedIn = !!currUser;
              // Check if this listing is already in the user's wishlist
              const isWishlisted = isLoggedIn &&
                currUser.wishlist &&
                currUser.wishlist.some(id => id.toString() === listing._id.toString());
            %>

            <button
              class="like-btn <%= isWishlisted ? 'liked' : '' %>"
        onclick="toggleLike(this, '<%= listing._id %>', '<%= isLoggedIn %>')"
              aria-label="<%= isWishlisted ? 'Remove from wishlist' : 'Save to wishlist' %>"
              title="<%= isWishlisted ? 'Remove from wishlist' : 'Save to wishlist' %>"
            >
              <i class="<%= isWishlisted ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
            </button>

            <!-- Card link -->
            <a
              href="/listings/<%= listing._id %>"
              class="listing-card"
              aria-label="View <%= listing.title %>"
            >

              <!-- Image — optimized via Cloudinary transformations -->
              <div class="listing-card-image-wrapper">
                <img
                  src="<%= cardImageUrl %>"
                  alt="<%= listing.title %>"
                  class="listing-card-image"
                  loading="lazy"
                  width="600"
                  height="450"
                />
                <div class="listing-price-badge">
                  &#8377;<%= listing.price.toLocaleString("en-IN") %><span>/night</span>
                </div>
                <% if (listing.category) { %>
                  <div class="listing-category-tag">
                    <%= listing.category %>
                  </div>
                <% } %>
              </div>

              <!-- Card Body -->
              <div class="listing-card-body">
                <h2 class="listing-card-title"><%= listing.title %></h2>
                <p class="listing-card-location">
                  <i class="fa-solid fa-location-dot me-1"></i>
                  <%= listing.location %>, <%= listing.country %>
                </p>

                <!-- FIX: Real average rating; shows "New" when no reviews exist -->
                <div class="listing-card-rating">
                  <% if (avgRating) { %>
                    <i class="fa-solid fa-star"></i>
                    <span><%= avgRating %></span>
                    <span class="rating-count">(<%= listing.reviews.length %>)</span>
                  <% } else { %>
                    <span class="rating-new">
                      <i class="fa-regular fa-star me-1"></i>New
                    </span>
                  <% } %>
                </div>
              </div>

            </a>
          </div>

        <% } %>
      </div>

      <!-- Pagination (rendered only when totalPages is passed from route) -->
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <nav class="listings-pagination" aria-label="Listings pages">
          <% for (let p = 1; p <= totalPages; p++) { %>
            <a
              href="/listings?page=<%= p %><%= typeof category !== 'undefined' && category ? '&category=' + category : '' %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %><%= typeof maxPrice !== 'undefined' && maxPrice ? '&maxPrice=' + maxPrice : '' %><%= typeof sort !== 'undefined' && sort ? '&sort=' + sort : '' %>"
              class="page-btn <%= (typeof currentPage !== 'undefined' && currentPage == p) ? 'active' : '' %>"
            ><%= p %></a>
          <% } %>
        </nav>
      <% } %>

    <% } else { %>

      <!-- Empty State -->
      <div class="listings-empty">
        <div class="listings-empty-icon-wrapper">
          <i class="fa-regular fa-compass"></i>
        </div>
        <h3>No properties found</h3>
        <p>
          <% if (hasFilters) { %>
            Try different search terms or
            <a href="/listings" class="text-brand">browse all listings</a>.
          <% } else { %>
            Be the first to add a property!
          <% } %>
        </p>
        <% if (!hasFilters) { %>
          <a href="<%= currUser ? '/listings/new' : '/login' %>" class="btn btn-add-listing mt-3">
            <i class="fa-solid fa-plus me-2"></i>Add First Listing
          </a>
        <% } %>
      </div>

    <% } %>

  </div>
</section>

<script>
  /*
   * toggleLike — wishlist heart button
   * FIX 1: isLoggedIn is injected from EJS — guests are sent to /login
   * FIX 2: Errors from the fetch are surfaced as a toast, not silently ignored
   */
  function toggleLike(btn, listingId, isLoggedIn) {
    // Redirect guests to login instead of showing fake feedback
    if (!isLoggedIn) {
      window.location.href = '/login?next=/listings';
      return;
    }

    const wasLiked = btn.classList.contains('liked');
    const isNowLiked = !wasLiked;

    // Optimistic UI update
    btn.classList.toggle('liked', isNowLiked);
    const icon = btn.querySelector('i');
    icon.className = isNowLiked ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
    btn.setAttribute('aria-label', isNowLiked ? 'Remove from wishlist' : 'Save to wishlist');

    // Bounce animation
    btn.style.transform = 'scale(1.3)';
    setTimeout(() => { btn.style.transform = ''; }, 200);

    // Send to server — roll back on failure
    fetch(`/wishlist/toggle/${listingId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(res => {
      if (!res.ok) throw new Error('Server error');
      return res.json();
    })
    .then(() => {
      showToast(
        isNowLiked ? 'fa-solid fa-heart' : 'fa-regular fa-heart',
        isNowLiked ? '#e85d3a' : '#6b7280',
        isNowLiked ? 'Saved to wishlist' : 'Removed from wishlist'
      );
    })
    .catch(() => {
      // Roll back the optimistic update on failure
      btn.classList.toggle('liked', wasLiked);
      icon.className = wasLiked ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
      showToast('fa-solid fa-circle-exclamation', '#dc2626', 'Could not update wishlist');
    });
  }

  /*
   * showToast — reusable toast notification
   * FIX: @keyframes is no longer injected on every call; it lives in index.css
   */
  function showToast(iconClass, iconColor, message) {
    const existing = document.getElementById('likeToast');
    if (existing) existing.remove();

    const toast = document.createElement('div');
    toast.id = 'likeToast';
    toast.className = 'listing-toast';
    toast.innerHTML = `<i class="${iconClass}" style="color:${iconColor}"></i> ${message}`;
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.classList.add('toast-hide');
      setTimeout(() => toast.remove(), 300);
    }, 2200);
  }
</script>
