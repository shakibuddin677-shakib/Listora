    <!-- COLLAPSIBLE CONTENT -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left nav links — only Explore, no duplicate Add Listing -->
      <ul class="navbar-nav me-auto gap-1">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- Right: dark toggle + auth -->
      <ul class="navbar-nav align-items-lg-center gap-2">

        <!-- Dark mode toggle — desktop only -->
        <li class="nav-item d-none d-lg-flex align-items-center">
          <button class="dark-toggle" id="darkToggleDesktop" onclick="toggleDarkMode()" aria-label="Toggle dark mode">
            <i class="fa-solid fa-moon" id="darkIconDesktop"></i>
          </button>
        </li>

        <% if (!currUser) { %>

          <!-- NOT logged in -->
          <li class="nav-item">
            <a class="nav-link nav-signup-link" href="/signup">Sign Up</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-nav-login" href="/login">Log In</a>
          </li>

        <% } else { %>

          <!-- LOGGED IN: Wishlist icon + user dropdown -->
          <li class="nav-item">
            <a class="nav-icon-btn" href="/wishlist" aria-label="Wishlist">
              <i class="fa-regular fa-heart"></i>
            </a>
          </li>

          <!-- User avatar dropdown -->
          <li class="nav-item dropdown">
            <button
              class="nav-avatar-btn"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              aria-label="User menu"
            >
              <span class="nav-avatar-letter">
                <%= currUser.username.charAt(0).toUpperCase() %>
              </span>
              <span class="nav-avatar-name d-none d-xl-inline">
                <%= currUser.username %>
              </span>
              <i class="fa-solid fa-chevron-down nav-avatar-chevron"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end nav-dropdown">
              <li class="nav-dropdown-header">
                Signed in as <strong><%= currUser.username %></strong>
              </li>
              <li><hr class="dropdown-divider nav-divider"></li>
              <li>
                <a class="dropdown-item nav-dropdown-item" href="/listings/new">
                  <i class="fa-solid fa-plus"></i> Add Listing
                </a>
              </li>
              <li>
                <a class="dropdown-item nav-dropdown-item" href="/wishlist">
                  <i class="fa-regular fa-heart"></i> Wishlist
                </a>
