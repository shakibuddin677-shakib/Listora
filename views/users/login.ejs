<% layout("/layouts/boilerplate") %>

<div class="auth-page">
  <div class="auth-card">

    <!-- Logo -->
    <a href="/" class="auth-logo" aria-label="Listora — go to homepage">
      <svg class="listora-logo-icon" width="30" height="30" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="4" y="13" width="15" height="15" rx="1.5" fill="currentColor" opacity="0.15"/>
        <rect x="4" y="13" width="15" height="15" rx="1.5" stroke="currentColor" stroke-width="1.6" fill="none"/>
        <rect x="9.5" y="21" width="4" height="7" rx="1" fill="currentColor" opacity="0.7"/>
        <rect x="6" y="16" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.6"/>
        <rect x="14" y="16" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.6"/>
        <circle cx="24" cy="10" r="5" stroke="currentColor" stroke-width="1.8" fill="none"/>
        <circle cx="24" cy="10" r="2" fill="currentColor" opacity="0.5"/>
        <line x1="27.5" y1="13.5" x2="30" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="29" y1="15" x2="28" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="27.5" y1="16.5" x2="26.5" y2="18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="11.5" cy="9.5" r="2.5" fill="currentColor"/>
        <path d="M11.5 7C10.12 7 9 8.08 9 9.42c0 1.97 2.5 4.08 2.5 4.08S14 11.39 14 9.42C14 8.08 12.88 7 11.5 7z" fill="currentColor" opacity="0.3"/>
      </svg>
      <span class="auth-logo-name">Listora</span>
    </a>

    <h1 class="auth-heading">Welcome back</h1>
    <p class="auth-subtext">Log in to continue your journey.</p>

    <form action="/login" method="POST" id="login-form" novalidate>

      <!-- Username -->
      <div class="auth-field">
        <label for="username">Username</label>
        <div class="auth-input-wrap">
          <i class="ti ti-user icon" aria-hidden="true"></i>
          <input
            type="text"
            name="username"
            id="username"
            class="auth-input"
            placeholder="your_username"
            autocomplete="username"
            aria-describedby="username-err"
            required
          >
        </div>
        <p class="auth-err" id="username-err" role="alert">
          Please enter your username.
        </p>
      </div>

      <!-- Password -->
      <div class="auth-field">
        <label for="password">Password</label>
        <div class="auth-input-wrap has-toggle">
          <i class="ti ti-lock icon" aria-hidden="true"></i>
          <input
            type="password"
            name="password"
            id="password"
            class="auth-input"
            placeholder="••••••••"
            autocomplete="current-password"
            aria-describedby="password-err"
            required
          >
          <button
            type="button"
            class="pw-toggle"
            id="pw-tog"
            aria-label="Show password"
            aria-pressed="false"
          >
            <i class="ti ti-eye" id="pw-icon" aria-hidden="true"></i>
          </button>
        </div>
        <p class="auth-err" id="password-err" role="alert">
          Please enter your password.
        </p>
      </div>

      <button type="submit" class="auth-submit">
        <i class="ti ti-login" aria-hidden="true"></i>
        Log in
      </button>

    </form>

    <div class="auth-divider" aria-hidden="true">
      <hr><span>New to StayScape?</span><hr>
    </div>

    <p class="auth-footer">
      Don't have an account?
      <a href="/signup">Create one</a>
    </p>

  </div><!-- /.auth-card -->
</div><!-- /.auth-page -->

<script>
  // password show / hide toggle
  (function () {
    const btn  = document.getElementById('pw-tog');
    const inp  = document.getElementById('password');
    const icon = document.getElementById('pw-icon');

    if (!btn || !inp || !icon) return;

    btn.addEventListener('click', function () {
      const showing = inp.type === 'password';
      inp.type             = showing ? 'text'       : 'password';
      icon.className       = showing ? 'ti ti-eye-off' : 'ti ti-eye';
      this.setAttribute('aria-label',  showing ? 'Hide password' : 'Show password');
      this.setAttribute('aria-pressed', showing ? 'true' : 'false');
    });
  }());

</script>
