              <li><hr class="dropdown-divider nav-divider"></li>
              <li>
                <a class="dropdown-item nav-dropdown-item nav-dropdown-logout" href="/logout">
                  <i class="fa-solid fa-right-from-bracket"></i> Log Out
                </a>
              </li>
            </ul>
          </li>

        <% } %>

      </ul>
    </div>

  </div>
</nav>

<!-- ── SEARCH SECTION (proper wrapper so CSS #searchSection works) ── -->
<section id="searchSection">
  <div class="container">

    <!-- Search Bar -->
    <form action="/listings" method="GET" class="search-bar-form" id="searchForm">
      <div class="search-bar">

        <!-- Location -->
        <div class="search-field search-field-location">
          <label class="search-field-label">Where</label>
          <input
            type="text"
            name="search"
            class="search-field-input"
            placeholder="Search destinations..."
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            autocomplete="off"
            id="searchInput"
          />
        </div>

        <div class="search-divider"></div>

        <!-- Max Price — expanded range for budget + luxury -->
        <div class="search-field search-field-price">
          <label class="search-field-label">Max Price</label>
          <select name="maxPrice" class="search-field-input search-select">
            <option value="" <%= (typeof maxPrice === 'undefined' || maxPrice === '') ? 'selected' : '' %>>Any price</option>
            <option value="500"   <%= (typeof maxPrice !== 'undefined' && maxPrice == '500')   ? 'selected' : '' %>>Under ₹500</option>
            <option value="1000"  <%= (typeof maxPrice !== 'undefined' && maxPrice == '1000')  ? 'selected' : '' %>>Under ₹1,000</option>
            <option value="3000"  <%= (typeof maxPrice !== 'undefined' && maxPrice == '3000')  ? 'selected' : '' %>>Under ₹3,000</option>
            <option value="5000"  <%= (typeof maxPrice !== 'undefined' && maxPrice == '5000')  ? 'selected' : '' %>>Under ₹5,000</option>
            <option value="10000" <%= (typeof maxPrice !== 'undefined' && maxPrice == '10000') ? 'selected' : '' %>>Under ₹10,000</option>
            <option value="20000" <%= (typeof maxPrice !== 'undefined' && maxPrice == '20000') ? 'selected' : '' %>>Under ₹20,000</option>
          </select>
        </div>

        <div class="search-divider"></div>

        <!-- Sort -->
        <div class="search-field search-field-sort">
          <label class="search-field-label">Sort By</label>
          <select name="sort" class="search-field-input search-select">
            <option value=""           <%= (typeof sort === 'undefined' || sort === '') ? 'selected' : '' %>>Relevance</option>
            <option value="price_asc"  <%= (typeof sort !== 'undefined' && sort === 'price_asc')  ? 'selected' : '' %>>Price: Low → High</option>
            <option value="price_desc" <%= (typeof sort !== 'undefined' && sort === 'price_desc') ? 'selected' : '' %>>Price: High → Low</option>
            <option value="newest"     <%= (typeof sort !== 'undefined' && sort === 'newest')     ? 'selected' : '' %>>Newest First</option>
          </select>
        </div>

        <button type="submit" class="search-btn" aria-label="Search">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>

      </div>
    </form>

    <!-- ── Category Filter Chips ──
         FIX: All chips now preserve ALL active query params (search, maxPrice, sort)
         so clicking a category never silently resets your other filters. -->
    <div class="category-chips" id="categoryChips">

      <%
        const categories = [
          { value: "beach",    icon: "fa-umbrella-beach", label: "Beach"    },
          { value: "mountain", icon: "fa-mountain",       label: "Mountains"},
          { value: "city",     icon: "fa-city",           label: "City"     },
          { value: "forest",   icon: "fa-tree",           label: "Forest"   },
          { value: "desert",   icon: "fa-sun",            label: "Desert"   },
          { value: "lake",     icon: "fa-water",          label: "Lakes"    },
          { value: "heritage", icon: "fa-landmark",       label: "Heritage" },
          { value: "camping",  icon: "fa-campground",     label: "Camping"  },
        ];

        const activeCategory = typeof category !== 'undefined' ? category : '';
        const activeSearch   = typeof search   !== 'undefined' ? search   : '';
        const activeMaxPrice = typeof maxPrice !== 'undefined' ? maxPrice : '';
        const activeSort     = typeof sort     !== 'undefined' ? sort     : '';

        // Helper: build a chip URL preserving all current filters except category
        function chipUrl(catValue) {
          const params = [];
          if (catValue)      params.push('category=' + catValue);
          if (activeSearch)  params.push('search='   + encodeURIComponent(activeSearch));
          if (activeMaxPrice)params.push('maxPrice=' + activeMaxPrice);
          if (activeSort)    params.push('sort='     + activeSort);
          return '/listings' + (params.length ? '?' + params.join('&') : '');
        }
      %>

      <% for (let cat of categories) { %>
        <a
          href="<%= chipUrl(cat.value) %>"
          class="category-chip <%= activeCategory === cat.value ? 'active' : '' %>"
          aria-label="Filter by <%= cat.label %>"
        >
          <i class="fa-solid <%= cat.icon %>"></i>
          <span><%= cat.label %></span>
        </a>
      <% } %>

      <!-- Clear all filters -->
      <% if (activeCategory || activeSearch || activeMaxPrice || activeSort) { %>
        <a href="/listings" class="category-chip chip-clear">
          <i class="fa-solid fa-xmark"></i>
          <span>Clear all</span>
        </a>
      <% } %>

    </div>

  </div>
</section>

<script>
  function toggleDarkMode() {
    const html = document.documentElement;
    const newTheme = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    // FIX: renamed key from 'wandernest-theme' to 'listora-theme'
    localStorage.setItem('listora-theme', newTheme);
    updateDarkModeIcons(newTheme);
  }

  function updateDarkModeIcons(theme) {
    const isDark = theme === 'dark';
    document.querySelectorAll('[id^="darkIcon"]').forEach(icon => {
      icon.className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
    updateDarkModeIcons(currentTheme);
  });
</script>
